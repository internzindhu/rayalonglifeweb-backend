generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Hotel {
  id                     String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                   String
  website                String?
  location               String?
  address                String?
  chain_name             String?
  marketing_material     Json?
  min_nights             Int?
  rooms_count            Int?
  max_occupancy          Int?
  doctors_count          Int?
  medical_report_support Boolean?
  kid_friendly           Boolean?
  min_age                Int?
  created_at             DateTime?               @default(now()) @db.Timestamp(6)
  no_min_nights          Boolean                 @default(false)
  doctors_available      Boolean?
  remarks                String?
  updated_at             DateTime                @default(now()) @updatedAt @db.Timestamp(6)
  hotel_style_id         Int?
  description            String?
  price                  String?
  slogan_line            String?
  rating                 Decimal?                @db.Decimal(3, 2)
  reviews_count          Int                     @default(0)
  is_active              Boolean                 @default(true)
  property_type_raw      String?
  min_nights_raw         String?
  restrictions_raw       String?
  rooms_raw              String?
  min_age_raw            String?
  cuisine_raw            String?
  meal_plan_raw          String?
  doctors_raw            String?
  facilities_raw         String?
  activities_raw         String?
  unique_features        String?
  video_url              String?
  highlights             String[]
  google_maps_url        String?
  dining_features_raw    String?
  activities             HotelActivity[]
  cuisine_types          HotelCuisineType[]
  dining_features        HotelDiningFeature[]
  facilities             HotelFacility[]
  images                 HotelImage[]
  meal_plans             HotelMealPlan[]
  property_types         HotelPropertyType[]
  restrictions           HotelRestriction[]
  room_features          HotelRoomFeature[]
  setting_types          HotelSettingType[]
  wellness_offerings     HotelWellnessOffering[]
  hotel_style            HotelStyle?             @relation(fields: [hotel_style_id], references: [id], onUpdate: NoAction)
  inquiries              Inquiry[]
  monthly_prices         HotelMonthlyPrice[]

  @@map("hotels")
}

model HotelMonthlyPrice {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotel_id   String   @db.Uuid
  price      Decimal  @db.Decimal(10, 2)
  currency   String   @default("USD")
  valid_from DateTime @db.Date
  valid_to   DateTime @db.Date
  occupancy  String?
  priority   Int      @default(0)

  hotel      Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hotel_id, valid_from, valid_to], map: "idx_hotel_monthly_prices_hotel_dates")
  @@map("hotel_monthly_prices")
}

model HotelImage {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotel_id   String   @db.Uuid
  url        String
  sort_order Int      @default(0)
  is_primary Boolean  @default(false)
  caption    String?
  alt_text   String?
  created_at DateTime @default(now()) @db.Timestamp(6)
  hotel      Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([hotel_id], map: "idx_hotel_images_hotel_id")
  @@map("hotel_images")
}

model PropertyType {
  id     Int                 @id @default(autoincrement())
  name   String              @unique
  hotels HotelPropertyType[]

  @@map("property_types")
}

model Facility {
  id     Int             @id @default(autoincrement())
  name   String          @unique
  hotels HotelFacility[]

  @@map("facilities")
}

model RoomFeature {
  id     Int                @id @default(autoincrement())
  name   String             @unique
  hotels HotelRoomFeature[]

  @@map("room_features")
}

model DiningFeature {
  id     Int                  @id @default(autoincrement())
  name   String               @unique
  hotels HotelDiningFeature[]

  @@map("dining_features")
}

model MealPlan {
  id     Int             @id @default(autoincrement())
  name   String          @unique
  hotels HotelMealPlan[]

  @@map("meal_plans")
}

model CuisineType {
  id     Int                @id @default(autoincrement())
  name   String             @unique
  hotels HotelCuisineType[]

  @@map("cuisine_types")
}

model Activity {
  id     Int             @id @default(autoincrement())
  name   String          @unique
  hotels HotelActivity[]

  @@map("activities")
}

model Restriction {
  id     Int                @id @default(autoincrement())
  name   String             @unique
  hotels HotelRestriction[]

  @@map("restrictions")
}

model HotelStyle {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  hotels Hotel[]

  @@map("hotel_styles")
}

model SettingType {
  id     Int                @id @default(autoincrement())
  name   String             @unique
  hotels HotelSettingType[]

  @@map("setting_types")
}

model WellnessOffering {
  id     Int                     @id @default(autoincrement())
  name   String                  @unique
  hotels HotelWellnessOffering[]

  @@map("wellness_offerings")
}

model HotelPropertyType {
  hotel_id         String       @db.Uuid
  property_type_id Int
  hotel            Hotel        @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  property_type    PropertyType @relation(fields: [property_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, property_type_id])
  @@map("hotel_property_types")
}

model HotelFacility {
  hotel_id    String   @db.Uuid
  facility_id Int
  facility    Facility @relation(fields: [facility_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  hotel       Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, facility_id])
  @@map("hotel_facilities")
}

model HotelRoomFeature {
  hotel_id        String      @db.Uuid
  room_feature_id Int
  hotel           Hotel       @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  room_feature    RoomFeature @relation(fields: [room_feature_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, room_feature_id])
  @@map("hotel_room_features")
}

model HotelDiningFeature {
  hotel_id          String        @db.Uuid
  dining_feature_id Int
  dining_feature    DiningFeature @relation(fields: [dining_feature_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  hotel             Hotel         @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, dining_feature_id])
  @@map("hotel_dining_features")
}

model HotelMealPlan {
  hotel_id     String   @db.Uuid
  meal_plan_id Int
  hotel        Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  meal_plan    MealPlan @relation(fields: [meal_plan_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, meal_plan_id])
  @@map("hotel_meal_plans")
}

model HotelCuisineType {
  hotel_id        String      @db.Uuid
  cuisine_type_id Int
  cuisine_type    CuisineType @relation(fields: [cuisine_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  hotel           Hotel       @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, cuisine_type_id])
  @@map("hotel_cuisine_types")
}

model HotelActivity {
  hotel_id    String   @db.Uuid
  activity_id Int
  activity    Activity @relation(fields: [activity_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  hotel       Hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, activity_id])
  @@map("hotel_activities")
}

model HotelRestriction {
  hotel_id       String      @db.Uuid
  restriction_id Int
  hotel          Hotel       @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  restriction    Restriction @relation(fields: [restriction_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, restriction_id])
  @@map("hotel_restrictions")
}

model HotelSettingType {
  hotel_id        String      @db.Uuid
  setting_type_id Int
  hotel           Hotel       @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  setting_type    SettingType @relation(fields: [setting_type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, setting_type_id])
  @@map("hotel_setting_types")
}

model HotelWellnessOffering {
  hotel_id             String           @db.Uuid
  wellness_offering_id Int
  hotel                Hotel            @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  wellness_offering    WellnessOffering @relation(fields: [wellness_offering_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([hotel_id, wellness_offering_id])
  @@map("hotel_wellness_offerings")
}

model Inquiry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  hotel_id        String?   @db.Uuid
  hotel_name      String
  date_from       DateTime? @db.Date
  date_to         DateTime? @db.Date
  room_type       String?
  people          Int?
  transport_mode  String?
  flight_included String?
  extras          String?
  total_price     String?
  gender          String?
  full_name       String
  email           String
  country         String?
  mobile          String?
  comment         String?
  status          String    @default("new")
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  hotel           Hotel?    @relation(fields: [hotel_id], references: [id], onUpdate: NoAction)

  @@index([created_at(sort: Desc)])
  @@index([hotel_id])
  @@index([status])
  @@map("inquiries")
}

model Consultation {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gender            String?
  name              String
  country           String?
  email             String
  mobile            String?
  preferred_contact String?
  travel_month      String?
  budget_min        String?
  budget_max        String?
  number_of_nights  Int?
  schedule_datetime DateTime? @db.Timestamptz(6)
  comment           String?
  status            String    @default("new")
  created_at        DateTime  @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@index([status])
  @@map("consultations")
}

model Contact {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String
  email      String
  phone      String?
  subject    String?
  message    String
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@map("contacts")
}

model Voucher {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quantity            Int
  voucher_value       Int?
  custom_value        Int?
  sender_full_name    String
  sender_email        String
  sender_contact      String?
  receiver_first_name String
  receiver_last_name  String?
  receiver_email      String?
  receiver_contact    String?
  receive_method      String?
  invoice_to_company  Boolean  @default(false)
  notes               String?
  status              String   @default("pending")
  created_at          DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@index([status])
  @@map("vouchers")
}

model QuestionnaireSubmission {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String?
  answers     Json
  result_type String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)], map: "questionnaire_created_at_idx")
  @@map("questionnaire_submissions")
}

model NewsletterSubscriber {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String   @unique
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@map("newsletter_subscribers")
}

model CallAnExpertForm {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone          String
  name           String
  email          String
  scheduled_date String?
  scheduled_slot String?
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([created_at(sort: Desc)])
  @@map("call_an_expert_form")
}
